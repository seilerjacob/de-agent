dbt_project/target/
dbt_project/dbt_packages/
dbt_project/dbt_internal_packages/
dbt_project/logs/
logs/

# Agent tooling — transient, never committed
.claude/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db