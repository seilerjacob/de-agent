# Snowflake credentials for the reference/snowflake pipeline.
#
# Copy this file to `.env.snowflake` and fill in the values. `.env.snowflake`
# is gitignored and must never be committed.
#
# Load it into your shell before running the pipeline or dbt:
#     set -a && source .env.snowflake && set +a
#
# See docs/reference-snowflake.md for full setup instructions.

# Snowflake account identifier.
# Preferred format: <orgname>-<account_name>   (e.g. myorg-myaccount)
# Legacy format:    <account>.<region>.<cloud> (e.g. xy12345.us-east-1.aws)
# This is the single most common source of connection failures — find it
# under Admin > Accounts in Snowsight, or from the account URL.
SNOWFLAKE_ACCOUNT=

# Snowflake user login name.
SNOWFLAKE_USER=

# --- Authentication (choose ONE) -------------------------------------------

# Option 1: username / password.
# Leave blank if using key-pair auth below.
SNOWFLAKE_PASSWORD=

# Option 2: key-pair auth.
# Absolute path to the unencrypted PKCS#8 private key (.p8) file.
# If set, it takes precedence over SNOWFLAKE_PASSWORD.
SNOWFLAKE_PRIVATE_KEY_PATH=

# ---------------------------------------------------------------------------

# Role to assume (optional — defaults to the user's default role if blank).
# Must have privileges to CREATE SCHEMA / TABLE / VIEW / DYNAMIC TABLE in the
# target database.
SNOWFLAKE_ROLE=

# Virtual warehouse used for compute (ingestion writes, dbt builds, and the
# Dynamic Table refresh cycle). This is the warehouse NAME, not a size.
SNOWFLAKE_WAREHOUSE=

# Target database. The pipeline creates RAW / STAGING / INTERMEDIATE schemas
# inside this database.
SNOWFLAKE_DATABASE=
